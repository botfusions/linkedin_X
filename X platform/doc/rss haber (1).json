      "parameters": {
        "jsCode": "// Tüm haberleri al\nconst newsItems = $input.all();\n\n// Başlık\nlet formatted = \"📰 GÜNÜN HABERLERİ\\n\";\nformatted += \"═\".repeat(80) + \"\\n\\n\";\n\n// Her haberi formatla\nnewsItems.forEach((item, index) => {\n  const json = item.json;\n  \n  // Haber başlığı\n  formatted += `📌 ${index + 1}. HABER\\n`;\n  formatted += \"─\".repeat(80) + \"\\n\";\n  \n  // İçerik al\n  let text = json.text || json.content || json.body || 'İçerik yok';\n  \n  // String ise işle\n  if (typeof text === 'string') {\n    // { \"body\": \"...\" } formatını temizle\n    const bodyMatch = text.match(/\"body\":\\s*\"([^\"]+(?:\\\\.[^\"]*)*?)\"/);\n    if (bodyMatch && bodyMatch[1]) {\n      text = bodyMatch[1];\n    } else {\n      // Alternatif: Basitçe { \"body\": \" kısmını sil\n      text = text.replace(/^\\s*\\{\\s*\"body\":\\s*\"/i, '').replace(/\"\\s*\\}\\s*$/, '');\n    }\n  }\n  \n  // Eğer hala object ise\n  if (typeof text === 'object') {\n    text = text.body || text.text || text.content || JSON.stringify(text);\n  }\n  \n  // Escape karakterlerini temizle\n  text = text\n    .replace(/\\\\\"/g, '\"')        // \\\" -> \"\n    .replace(/\\\\n/g, ' ')        // \\n -> boşluk (escape edilmiş)\n    .replace(/\\\\t/g, ' ')        // \\t -> boşluk\n    .replace(/\\\\r/g, '')         // \\r -> sil\n    .replace(/\\\\/g, '')          // Kalan \\ karakterlerini sil\n    .replace(/\\s+/g, ' ')        // Çoklu boşlukları tek boşluğa çevir\n    .trim();\n  \n  // Maksimum 1600 karakter al\n  let preview = text.substring(0, 1600).trim();\n  \n  // Son cümleyi tamamla\n  const lastPunctuation = Math.max(\n    preview.lastIndexOf('.'),\n    preview.lastIndexOf('!'),\n    preview.lastIndexOf('?')\n  );\n  \n  // Son 100 karakter içinde noktalama varsa oradan kes\n  if (lastPunctuation > preview.length - 100 && lastPunctuation > 0) {\n    preview = preview.substring(0, lastPunctuation + 1);\n  }\n  \n  formatted += preview;\n  \n  if (text.length > 1600) {\n    formatted += \"...\";\n  }\n  \n  formatted += \"\\n\\n\";\n  formatted += \"─\".repeat(80) + \"\\n\\n\";\n});\n\n// İstatistik\nformatted += `✅ Toplam ${newsItems.length} haber\\n`;\nformatted += `⏰ ${new Date().toLocaleString('tr-TR')}\\n`;\nformatted += \"═\".repeat(80);\n\n// Output\nreturn [{ \n  json: { \n    formatted_output: formatted,\n    total_count: newsItems.length,\n    char_count: formatted.length,\n    processed_date: new Date().toISOString()\n  } \n}];"
      },
