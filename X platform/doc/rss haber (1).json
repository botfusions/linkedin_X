    {
      "parameters": {
        "jsCode": "// INPUT'tan gelen veriyi al - DOĞRU YÖNTEM\nconst rawBody = $json.text || $json.body || $json.output || $json.linkedin_post || '';\n\n// JSON string ise parse et\nlet cleanContent = '';\n\nif (typeof rawBody === 'string' && rawBody.trim().startsWith('{')) {\n  try {\n    const parsed = JSON.parse(rawBody);\n    cleanContent = parsed.body || rawBody;\n  } catch (e) {\n    cleanContent = rawBody;\n  }\n} else {\n  cleanContent = rawBody;\n}\n\n// 1. Markdown temizle\nlet cleanBody = cleanContent\n  .replace(/\\*\\*(.*?)\\*\\*/g, '$1')      // Bold kaldır\n  .replace(/__(.*?)__/g, '$1')          // Italic kaldır\n  .replace(/###\\s+/g, '')               // H3 kaldır\n  .replace(/##\\s+/g, '')                // H2 kaldır\n  .replace(/```[\\s\\S]*?```/g, '')       // Code block kaldır\n  .replace(/`(.*?)`/g, '$1')            // Inline code kaldır\n\n// 2. Hashtag'leri ayır\nconst hashtagMatch = cleanBody.match(/(#[\\wığüşöçİĞÜŞÖÇ]+\\s*)+$/);\nconst hashtags = hashtagMatch ? hashtagMatch[0].trim() : '';\nconst contentWithoutHashtags = cleanBody.replace(/(#[\\wığüşöçİĞÜŞÖÇ]+\\s*)+$/, '').trim();\n\n// 3. Karakter kontrolü\nlet finalContent = contentWithoutHashtags;\nconst MIN_CHARS = 1900;\nconst MAX_CHARS = 2500;\nconst targetMax = MAX_CHARS - hashtags.length - 10;\n\nif (finalContent.length > targetMax) {\n  let tempContent = finalContent.substring(0, targetMax);\n  const lastPeriod = Math.max(\n    tempContent.lastIndexOf('.'),\n    tempContent.lastIndexOf('!'),\n    tempContent.lastIndexOf('?')\n  );\n  if (lastPeriod > targetMax - 300) {\n    finalContent = tempContent.substring(0, lastPeriod + 1).trim();\n  } else {\n    const lastSpace = tempContent.lastIndexOf(' ');\n    finalContent = tempContent.substring(0, lastSpace).trim() + '...';\n  }\n}\n\n// 4. Satır aralarını düzenle\nfinalContent = finalContent\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .replace(/\\n\\s+\\n/g, '\\n\\n')\n  .trim();\n\n// 5. Final çıktı\nconst linkedinPost = `${finalContent}\\n\\n${hashtags}`;\n\n// 6. Return\nconst charCount = linkedinPost.length;\nconst contentLength = finalContent.length;\n\nreturn {\n  linkedin_post: linkedinPost,\n  char_count: charCount,\n  content_length: contentLength,\n  hashtags_length: hashtags.length,\n  status: charCount >= MIN_CHARS && charCount <= MAX_CHARS ? 'PERFECT' : (charCount < MIN_CHARS ? 'TOO_SHORT' : 'TOO_LONG'),\n  is_valid: charCount >= MIN_CHARS && charCount <= MAX_CHARS,\n  warning: charCount > MAX_CHARS ? `Content is ${charCount - MAX_CHARS} characters over limit` : (charCount < MIN_CHARS ? `Content is ${MIN_CHARS - charCount} characters short` : null),\n  raw_body_length: rawBody.length\n};"
      },
